new pdfs/

# macOS metadata (anywhere in tree)
.DS_Store
**/.DS_Store

# Python bytecode / caches
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Secrets / local env
.env

# Python packaging / virtual envs
*.egg-info/
.venv/
venv/
